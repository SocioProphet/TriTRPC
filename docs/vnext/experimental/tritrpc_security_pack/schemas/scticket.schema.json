{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.example/security/scticket.schema.json",
  "title": "TriRPC Service Capability Ticket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "typ",
    "ver",
    "iss",
    "jti",
    "iat",
    "nbf",
    "exp",
    "aud",
    "authorization_details"
  ],
  "properties": {
    "typ": {"type": "string", "const": "triticket+jwt"},
    "ver": {"type": "string", "const": "1"},
    "iss": {"type": "string", "minLength": 1},
    "sub_ref": {"type": "string", "minLength": 1},
    "jti": {"type": "string", "minLength": 8},
    "iat": {"type": "integer"},
    "nbf": {"type": "integer"},
    "exp": {"type": "integer"},
    "aud": {"type": "string", "minLength": 1},
    "workspace_id": {"type": "string"},
    "tenant_id": {"type": "string"},
    "authorization_details": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "action", "resource", "constraints"],
        "properties": {
          "type": {"type": "string", "const": "trirpc"},
          "action": {"type": "string", "minLength": 1},
          "resource": {"type": "object"},
          "constraints": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "upstream_ref": {"type": "string"},
    "policy": {"type": "object"},
    "evidence": {"type": "object"}
  }
}
