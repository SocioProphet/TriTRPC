          "ctrl243_trits": [0, 0, 1, 0, 0],
          "ctrl243_byte": 9,
          "delta_type": "degradation.cluster.v1",
          "payload": {
            "epoch": 42,
            "scope": "cohort",
            "route_h": 17,
