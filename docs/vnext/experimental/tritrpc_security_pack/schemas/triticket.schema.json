{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.example/security/triticket.schema.json",
  "title": "TriRPC Browser Capability Ticket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "typ",
    "ver",
    "iss",
    "jti",
    "iat",
    "nbf",
    "exp",
    "aud",
    "authorization_details",
    "cnf"
  ],
  "properties": {
    "typ": {
      "type": "string",
      "const": "triticket+jwt"
    },
    "ver": {
      "type": "string",
      "const": "1"
    },
    "iss": {
      "type": "string",
      "minLength": 1
    },
    "sub_ref": {
      "type": "string",
      "minLength": 1
    },
    "sid_ref": {
      "type": "string",
      "minLength": 1
    },
    "jti": {
      "type": "string",
      "minLength": 16
    },
    "iat": {
      "type": "integer"
    },
    "nbf": {
      "type": "integer"
    },
    "exp": {
      "type": "integer"
    },
    "aud": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "authorization_details": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "action",
          "resource",
          "constraints"
        ],
        "properties": {
          "type": {
            "type": "string",
            "const": "trirpc"
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "resource": {
            "type": "object"
          },
          "constraints": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "http_method": {
                "type": "string"
              },
              "http_path": {
                "type": "string"
              },
              "max_requests": {
                "type": "integer",
                "minimum": 1
              },
              "max_output_tokens": {
                "type": "integer",
                "minimum": 1
              },
              "ttl_seconds": {
                "type": "integer",
                "minimum": 1
              },
              "one_time": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "cnf": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jkt"
      ],
      "properties": {
        "jkt": {
          "type": "string",
          "minLength": 16
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hash": {
          "type": "string",
          "pattern": "^sha256:.+"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "type": "string"
        },
        "cairn_ref": {
          "type": "string"
        }
      }
    }
  }
}
